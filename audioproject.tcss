AudioDirectoryApp {
    background: $boost;
    height: 5;
    margin: 1;
    min-width: 40;
    padding: 1;
}

Screen {
    align: center middle;
    padding: 1;
}


#buttons {
    height: auto;
    width: auto;
    padding: 1;
}

#pressed_save {
    height: auto;
    width: auto;
    padding: 0;
    align: right middle;
}

ContentSwitcher {
    border: round $primary;
    width: 90%;
    height: 1fr;
}

.container {
    height: auto;
    width: auto;
}

Switch {
    height: auto;
    width: auto;
}

.label {
    height: auto;
    content-align: center middle;
    width: auto;
}